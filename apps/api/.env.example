# Copy to .env and fill in real values. Never commit the real .env file.

ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://fintrack:changeme@localhost:5432/fintrack
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_QUERY_TIMEOUT_SECONDS=5

REDIS_URL=redis://localhost:6379/0

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-me-with-a-real-secret-never-commit-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=10

REGISTER_RATE_LIMIT_ATTEMPTS=5
REGISTER_RATE_LIMIT_WINDOW_MINUTES=15
